{
  "React Function Component": {
    "prefix": "rfc",
    "body": [
      "interface ${1:${TM_FILENAME_BASE/(.*)/${1:/pascalcase}/}}Props {",
      "  $2",
      "}",
      "",
      "export default function ${1:${TM_FILENAME_BASE/(.*)/${1:/pascalcase}/}}({ $3 }: ${1:${TM_FILENAME_BASE/(.*)/${1:/pascalcase}/}}Props) {",
      "  return (",
      "    <div>",
      "      $0",
      "    </div>",
      "  )",
      "}"
    ],
    "description": "React functional component with props interface"
  },
  "React Function Component (no props)": {
    "prefix": "rfce",
    "body": [
      "export default function ${1:${TM_FILENAME_BASE/(.*)/${1:/pascalcase}/}}() {",
      "  return (",
      "    <div>",
      "      $0",
      "    </div>",
      "  )",
      "}"
    ],
    "description": "React functional component without props"
  },
  "useState": {
    "prefix": "us",
    "body": [
      "const [${1:state}, set${1/(.*)/${1:/pascalcase}/}] = useState<${2:type}>(${3:initialValue})"
    ],
    "description": "useState hook"
  },
  "useEffect": {
    "prefix": "ue",
    "body": [
      "useEffect(() => {",
      "  $1",
      "  return () => {",
      "    $2",
      "  }",
      "}, [$3])"
    ],
    "description": "useEffect hook with cleanup"
  },
  "useCallback": {
    "prefix": "ucb",
    "body": [
      "const ${1:callback} = useCallback(($2) => {",
      "  $3",
      "}, [$4])"
    ],
    "description": "useCallback hook"
  },
  "useMemo": {
    "prefix": "um",
    "body": [
      "const ${1:value} = useMemo(() => {",
      "  return $2",
      "}, [$3])"
    ],
    "description": "useMemo hook"
  },
  "useRef": {
    "prefix": "ur",
    "body": [
      "const ${1:ref} = useRef<${2:type}>(${3:null})"
    ],
    "description": "useRef hook"
  },
  "useContext": {
    "prefix": "uc",
    "body": [
      "const ${1:value} = useContext(${2:Context})"
    ],
    "description": "useContext hook"
  },
  "useReducer": {
    "prefix": "urd",
    "body": [
      "const [${1:state}, ${2:dispatch}] = useReducer(${3:reducer}, ${4:initialState})"
    ],
    "description": "useReducer hook"
  },
  "Custom Hook": {
    "prefix": "rch",
    "body": [
      "export function use${1:HookName}($2) {",
      "  $0",
      "}"
    ],
    "description": "Custom React hook"
  },
  "React Context": {
    "prefix": "rctx",
    "body": [
      "import { createContext, useContext, useState } from 'react'",
      "",
      "interface ${1:Name}ContextType {",
      "  $2",
      "}",
      "",
      "const ${1:Name}Context = createContext<${1:Name}ContextType | undefined>(undefined)",
      "",
      "export function ${1:Name}Provider({ children }: { children: React.ReactNode }) {",
      "  return (",
      "    <${1:Name}Context.Provider value={{ $3 }}>",
      "      {children}",
      "    </${1:Name}Context.Provider>",
      "  )",
      "}",
      "",
      "export function use${1:Name}() {",
      "  const context = useContext(${1:Name}Context)",
      "  if (!context) throw new Error('use${1:Name} must be used within ${1:Name}Provider')",
      "  return context",
      "}"
    ],
    "description": "React context with provider and hook"
  },
  "console.log": {
    "prefix": "cl",
    "body": ["console.log($1)"],
    "description": "console.log"
  },
  "console.log variable": {
    "prefix": "clv",
    "body": ["console.log('${1:variable}:', ${1:variable})"],
    "description": "console.log with label"
  }
}
